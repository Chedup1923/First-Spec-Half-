<!DOCTYPE html>
<html lang="en" data-theme="dark" data-accent="indigo">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SELISE Stationery Portal</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<link rel="stylesheet" href="styles.css">
</head>
<body>

<!-- Three.js Canvas -->
<canvas id="bg-canvas"></canvas>

<!-- Toast Container -->
<div id="toast-container"></div>

<!-- Loading Overlay -->
<div class="loading-overlay" id="loading-overlay">
  <div class="loading-spinner"></div>
  <div class="loading-text">SELISE Portal</div>
</div>

<!-- ===================== WELCOME PAGE ===================== -->
<div class="page active" id="welcome-page">
  <div class="welcome-hero">
    <div class="welcome-badge">✦ Enterprise Resource Management</div>
    <div class="welcome-title">SELISE<br>Stationery Portal</div>
    <div class="welcome-sub">A unified platform for requesting, tracking, and managing office stationery resources across your organisation.</div>
  </div>
  <div class="role-cards">
    <div class="role-card" onclick="selectRole('admin')">
      <div class="role-icon">🛡️</div>
      <div class="role-label">Admin</div>
      <div class="role-desc">Manage requests, approve or reject, and oversee all stationery operations.</div>
    </div>
    <div class="role-card" onclick="selectRole('employee')">
      <div class="role-icon">👤</div>
      <div class="role-label">Employee</div>
      <div class="role-desc">Submit stationery requests and track the status of your submissions.</div>
    </div>
  </div>
</div>

<!-- ===================== AUTH PAGE ===================== -->
<div class="page" id="auth-page">
  <div class="auth-container">
    <div class="auth-logo">
      <div class="auth-logo-text">✦ SELISE Portal</div>
      <div><span class="auth-role-badge" id="auth-role-label">Admin</span></div>
    </div>

    <!-- Tabs -->
    <div class="auth-tabs" id="auth-tabs">
      <button class="auth-tab active" onclick="switchAuthTab('login')">Login</button>
      <button class="auth-tab" onclick="switchAuthTab('register')">Register</button>
      <button class="auth-tab" onclick="switchAuthTab('forgot')">Forgot</button>
    </div>

    <!-- LOGIN CARD -->
    <div class="auth-card active" id="card-login">
      <div class="auth-title">Welcome back 👋</div>
      <div class="auth-subtitle">Sign in to access your portal</div>

      <button class="btn btn-ms" onclick="mockMicrosoftLogin()">
        <svg width="18" height="18" viewBox="0 0 21 21"><rect x="1" y="1" width="9" height="9" fill="#f25022"/><rect x="11" y="1" width="9" height="9" fill="#00a4ef"/><rect x="1" y="11" width="9" height="9" fill="#7fba00"/><rect x="11" y="11" width="9" height="9" fill="#ffb900"/></svg>
        Continue with Microsoft
      </button>
      <div class="divider">or use email</div>

      <div id="login-step1">
        <div class="form-group">
          <label class="form-label">Email Address</label>
          <input class="form-input" type="email" id="login-email" placeholder="you@selise.com">
        </div>
        <button class="btn btn-primary" onclick="loginStep1()">Continue →</button>
      </div>

      <div id="login-step2" style="display:none">
        <div class="form-group">
          <label class="form-label">Verification Code</label>
          <div class="otp-demo" id="login-otp-demo">Demo code: <strong id="login-demo-code">------</strong></div>
          <div class="otp-grid" id="login-otp-grid">
            <input class="otp-input" maxlength="1" oninput="otpNext(this,'login-otp-grid')" onkeydown="otpBack(event,this,'login-otp-grid')">
            <input class="otp-input" maxlength="1" oninput="otpNext(this,'login-otp-grid')" onkeydown="otpBack(event,this,'login-otp-grid')">
            <input class="otp-input" maxlength="1" oninput="otpNext(this,'login-otp-grid')" onkeydown="otpBack(event,this,'login-otp-grid')">
            <input class="otp-input" maxlength="1" oninput="otpNext(this,'login-otp-grid')" onkeydown="otpBack(event,this,'login-otp-grid')">
            <input class="otp-input" maxlength="1" oninput="otpNext(this,'login-otp-grid')" onkeydown="otpBack(event,this,'login-otp-grid')">
            <input class="otp-input" maxlength="1" oninput="otpNext(this,'login-otp-grid')" onkeydown="otpBack(event,this,'login-otp-grid')">
          </div>
        </div>
        <button class="btn btn-primary" onclick="loginStep2()">Verify Code</button>
        <div style="text-align:center;margin-top:10px"><span class="auth-link" onclick="backToStep1()">← Change email</span></div>
      </div>

      <div id="login-step3" style="display:none">
        <div class="form-group">
          <label class="form-label">Password</label>
          <div class="input-wrap">
            <input class="form-input" type="password" id="login-password" placeholder="Enter password">
            <button class="eye-toggle" type="button" onclick="toggleEye('login-password',this)">👁</button>
          </div>
        </div>
        <div class="remember-row">
          <label class="checkbox-wrap"><input type="checkbox" id="remember-me"> Remember me</label>
          <span class="auth-link" onclick="switchAuthTab('forgot')">Forgot password?</span>
        </div>
        <button class="btn btn-primary" onclick="loginStep3()">Sign In →</button>
      </div>
    </div>
    <!-- REGISTER CARD -->
    <div class="auth-card" id="card-register">
      <button class="back-btn" onclick="switchAuthTab('login')">← Back to Login</button>
      <div class="auth-title">Create Account</div>
      <div class="auth-subtitle" id="register-subtitle">Register as Admin</div>

      <button class="btn btn-ms" onclick="mockMicrosoftLogin()">
        <svg width="18" height="18" viewBox="0 0 21 21"><rect x="1" y="1" width="9" height="9" fill="#f25022"/><rect x="11" y="1" width="9" height="9" fill="#00a4ef"/><rect x="1" y="11" width="9" height="9" fill="#7fba00"/><rect x="11" y="11" width="9" height="9" fill="#ffb900"/></svg>
        Register with Microsoft
      </button>
      <div class="divider">or fill in details</div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">First Name</label>
          <input class="form-input" id="reg-fname" placeholder="John">
        </div>
        <div class="form-group">
          <label class="form-label">Last Name</label>
          <input class="form-input" id="reg-lname" placeholder="Doe">
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Work Email</label>
        <input class="form-input" id="reg-email" type="email" placeholder="john.doe@selise.com">
      </div>
      <div class="form-group" id="reg-dept-wrap" style="display:none">
        <label class="form-label">Department</label>
        <select class="form-input select-input" id="reg-dept">
          <option value="">Select department</option>
          <option>Engineering</option><option>Marketing</option><option>HR</option><option>Finance</option><option>Operations</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Password</label>
        <div class="input-wrap">
          <input class="form-input" type="password" id="reg-password" placeholder="10-15 characters" oninput="checkStrength(this.value)">
          <button class="eye-toggle" type="button" onclick="toggleEye('reg-password',this)">👁</button>
        </div>
        <div class="strength-bar"><div class="strength-seg" id="s1"></div><div class="strength-seg" id="s2"></div><div class="strength-seg" id="s3"></div><div class="strength-seg" id="s4"></div></div>
        <div class="strength-label" id="strength-label">Enter a password</div>
      </div>
      <div class="form-group">
        <label class="form-label">Confirm Password</label>
        <div class="input-wrap">
          <input class="form-input" type="password" id="reg-confirm" placeholder="Repeat password" oninput="checkMatch()">
          <button class="eye-toggle" type="button" onclick="toggleEye('reg-confirm',this)">👁</button>
        </div>
        <div id="match-status" style="font-size:12px;margin-top:6px"></div>
      </div>
      <button class="btn btn-primary" onclick="doRegister()">Create Account →</button>
    </div>

    <!-- FORGOT PASSWORD CARD -->
    <div class="auth-card" id="card-forgot">
      <button class="back-btn" onclick="switchAuthTab('login')">← Back to Login</button>
      <div class="auth-title">Reset Password</div>
      <div class="auth-subtitle">We'll send you a recovery code</div>

      <div class="step-indicator">
        <div class="step-dot active" id="fp-dot-1">1</div>
        <div class="step-line"></div>
        <div class="step-dot inactive" id="fp-dot-2">2</div>
        <div class="step-line"></div>
        <div class="step-dot inactive" id="fp-dot-3">3</div>
      </div>

      <div id="fp-step1">
        <div class="form-group">
          <label class="form-label">Email Address</label>
          <input class="form-input" id="fp-email" type="email" placeholder="your@email.com">
        </div>
        <button class="btn btn-primary" onclick="fpStep1()">Send Code →</button>
      </div>

      <div id="fp-step2" style="display:none">
        <div class="otp-demo" id="fp-otp-demo">Demo code: <strong id="fp-demo-code">------</strong></div>
        <div class="form-group">
          <label class="form-label">6-Digit OTP</label>
          <div class="otp-grid" id="fp-otp-grid">
            <input class="otp-input" maxlength="1" oninput="otpNext(this,'fp-otp-grid')" onkeydown="otpBack(event,this,'fp-otp-grid')">
            <input class="otp-input" maxlength="1" oninput="otpNext(this,'fp-otp-grid')" onkeydown="otpBack(event,this,'fp-otp-grid')">
            <input class="otp-input" maxlength="1" oninput="otpNext(this,'fp-otp-grid')" onkeydown="otpBack(event,this,'fp-otp-grid')">
            <input class="otp-input" maxlength="1" oninput="otpNext(this,'fp-otp-grid')" onkeydown="otpBack(event,this,'fp-otp-grid')">
            <input class="otp-input" maxlength="1" oninput="otpNext(this,'fp-otp-grid')" onkeydown="otpBack(event,this,'fp-otp-grid')">
            <input class="otp-input" maxlength="1" oninput="otpNext(this,'fp-otp-grid')" onkeydown="otpBack(event,this,'fp-otp-grid')">
          </div>
        </div>
        <button class="btn btn-primary" onclick="fpStep2()">Verify →</button>
      </div>

      <div id="fp-step3" style="display:none">
        <div class="form-group">
          <label class="form-label">New Password</label>
          <div class="input-wrap">
            <input class="form-input" type="password" id="fp-new-pass" placeholder="New password" oninput="checkStrength(this.value,'fp')">
            <button class="eye-toggle" type="button" onclick="toggleEye('fp-new-pass',this)">👁</button>
          </div>
          <div class="strength-bar"><div class="strength-seg" id="fps1"></div><div class="strength-seg" id="fps2"></div><div class="strength-seg" id="fps3"></div><div class="strength-seg" id="fps4"></div></div>
        </div>
        <div class="form-group">
          <label class="form-label">Confirm Password</label>
          <div class="input-wrap">
            <input class="form-input" type="password" id="fp-confirm-pass" placeholder="Confirm">
            <button class="eye-toggle" type="button" onclick="toggleEye('fp-confirm-pass',this)">👁</button>
          </div>
        </div>
        <button class="btn btn-primary" onclick="fpStep3()">Reset Password →</button>
      </div>
    </div>

    <div class="form-footer" style="margin-top:16px">
      <span class="auth-link" onclick="goToWelcome()">← Choose different role</span>
    </div>
  </div>
</div>

<!-- ===================== DASHBOARD PAGE ===================== -->
<div class="page" id="dashboard-page">
  <div class="dash-layout">
    <!-- SIDEBAR -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-logo">
        <div class="sidebar-logo-icon">✦</div>
        <div class="sidebar-logo-text">SELISE</div>
      </div>

      <!-- Employee Nav -->
      <div id="emp-nav">
        <div class="sidebar-section-label">Navigation</div>
        <div class="nav-item active" onclick="switchView('emp-overview','emp-nav')">
          <span class="nav-icon">📊</span> Overview
        </div>
        <div class="nav-item" onclick="switchView('emp-requests','emp-nav')">
          <span class="nav-icon">📋</span> My Requests
          <span class="nav-badge" id="emp-req-badge">0</span>
        </div>
        <div class="nav-item" onclick="switchView('emp-new-request','emp-nav')">
          <span class="nav-icon">➕</span> New Request
        </div>
        <div class="nav-item" onclick="switchView('emp-notifications','emp-nav')">
          <span class="nav-icon">🔔</span> Notifications
          <span class="nav-badge" id="emp-notif-sidebar-badge" style="display:none;background:var(--danger)">!</span>
        </div>
        <div class="sidebar-section-label">Account</div>
        <div class="nav-item" onclick="switchView('emp-profile','emp-nav')">
          <span class="nav-icon">👤</span> Profile
        </div>
        <div class="nav-item" onclick="switchView('emp-settings','emp-nav')">
          <span class="nav-icon">⚙️</span> Settings
        </div>
      </div>

      <!-- Admin Nav -->
      <div id="adm-nav" style="display:none">
        <div class="sidebar-section-label">Management</div>
        <div class="nav-item active" onclick="switchView('adm-overview','adm-nav')">
          <span class="nav-icon">📊</span> Overview
        </div>
        <div class="nav-item" onclick="switchView('adm-requests','adm-nav')">
          <span class="nav-icon">📋</span> All Requests
          <span class="nav-badge" id="adm-pending-badge">0</span>
        </div>
        <div class="nav-item" onclick="switchView('adm-employees','adm-nav')">
          <span class="nav-icon">👥</span> Employees
        </div>
        <div class="sidebar-section-label">Account</div>
        <div class="nav-item" onclick="switchView('adm-profile','adm-nav')">
          <span class="nav-icon">👤</span> Profile
        </div>
        <div class="nav-item" onclick="switchView('adm-settings','adm-nav')">
          <span class="nav-icon">⚙️</span> Settings
        </div>
      </div>

      <div class="sidebar-bottom">
        <div class="user-chip" onclick="doLogout()">
          <div class="user-avatar" id="sidebar-avatar">U</div>
          <div class="user-info">
            <div class="user-name" id="sidebar-name">User</div>
            <div class="user-role" id="sidebar-role">Employee</div>
          </div>
          <span style="font-size:14px;color:var(--text-faint)">↩</span>
        </div>
      </div>
    </aside>

    <!-- MAIN AREA -->
    <div style="flex:1;display:flex;flex-direction:column;min-width:0;">
      <div class="topbar">
        <div class="topbar-title" id="topbar-title">Overview</div>
        <div class="topbar-actions">
          <span class="admin-topbar-badge" id="admin-badge" style="display:none">ADMIN</span>
          <div class="icon-btn" id="notif-btn" onclick="toggleNotifPanel()">🔔<span class="notif-dot" id="notif-dot" style="display:none"></span></div>
          <div class="icon-btn" onclick="toggleTheme()">🌙</div>
        </div>
      </div>

      <div class="main-content" id="main-content">

        <!-- ===== EMPLOYEE VIEWS ===== -->

        <!-- Employee Overview -->
        <div class="view active" id="emp-overview">
          <div class="breadcrumb"><span>Dashboard</span><span class="sep">›</span><span class="current">Overview</span></div>
          <div class="stats-grid" id="emp-stats-grid"></div>
          <div class="section-header">
            <div class="section-title">Recent Requests</div>
            <button class="btn btn-ghost btn-sm" onclick="switchView('emp-requests','emp-nav')">View All →</button>
          </div>
          <div class="table-wrap" id="emp-recent-table"></div>
        </div>

        <!-- Employee Requests -->
        <div class="view" id="emp-requests">
          <div class="breadcrumb"><span>Dashboard</span><span class="sep">›</span><span class="current">My Requests</span></div>
          <div class="section-header">
            <div class="section-title">My Requests</div>
            <div class="section-controls">
              <input class="search-input" placeholder="Search requests..." oninput="filterEmpRequests(this.value)" id="emp-search">
              <select class="select-input" onchange="sortEmpRequests(this.value)">
                <option value="date-desc">Newest First</option>
                <option value="date-asc">Oldest First</option>
                <option value="status">By Status</option>
                <option value="urgency">By Urgency</option>
              </select>
              <button class="btn btn-primary btn-sm" onclick="switchView('emp-new-request','emp-nav')">+ New</button>
            </div>
          </div>
          <div class="table-wrap" id="emp-requests-table"></div>
          <div class="pagination" id="emp-pagination"></div>
        </div>

        <!-- New Request Form -->
        <div class="view" id="emp-new-request">
          <div class="breadcrumb"><span>Dashboard</span><span class="sep">›</span><span class="current">New Request</span></div>
          <div class="section-title" style="margin-bottom:20px">Submit New Request</div>
          <div class="form-card">
            <div class="form-grid">
              <div class="form-group">
                <label class="form-label">Category</label>
                <select class="form-input select-input" id="req-category">
                  <option value="">Select category</option>
                  <option>Writing Instruments</option>
                  <option>Paper & Notebooks</option>
                  <option>Desk Accessories</option>
                  <option>Folders & Binders</option>
                  <option>Printing Supplies</option>
                  <option>IT Peripherals</option>
                  <option>Other</option>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">Item Name</label>
                <input class="form-input" id="req-item" placeholder="e.g. Blue ballpoint pens">
              </div>
              <div class="form-group">
                <label class="form-label">Quantity</label>
                <input class="form-input" type="number" id="req-qty" placeholder="1" min="1">
              </div>
              <div class="form-group">
                <label class="form-label">Urgency</label>
                <select class="form-input select-input" id="req-urgency">
                  <option value="low">Low – within a month</option>
                  <option value="medium" selected>Medium – within a week</option>
                  <option value="high">High – ASAP</option>
                </select>
              </div>
            </div>
            <div class="form-group">
              <label class="form-label">Additional Notes</label>
              <textarea class="form-input" id="req-notes" placeholder="Any specific brand, size, colour preferences..."></textarea>
            </div>
            <div class="flex-end">
              <button class="btn btn-ghost" onclick="clearRequestForm()">Clear</button>
              <button class="btn btn-primary" onclick="submitRequest()">Submit Request →</button>
            </div>
          </div>
        </div>

        <!-- Employee Notifications -->
        <div class="view" id="emp-notifications">
          <div class="breadcrumb"><span>Dashboard</span><span class="sep">›</span><span class="current">Notifications</span></div>
          <div class="section-title" style="margin-bottom:20px">Notifications</div>
          <div class="form-card" id="emp-notif-list"></div>
        </div>

        <!-- Employee Profile -->
        <div class="view" id="emp-profile">
          <div class="breadcrumb"><span>Dashboard</span><span class="sep">›</span><span class="current">Profile</span></div>
          <div class="profile-hero">
            <div class="profile-avatar-lg" id="emp-profile-avatar">U</div>
            <div>
              <div class="profile-name" id="emp-profile-name">User</div>
              <div class="profile-email" id="emp-profile-email">user@selise.com</div>
              <div style="margin-top:8px"><span class="badge badge-approved">Employee</span></div>
            </div>
          </div>
          <div class="settings-card">
            <div class="settings-row">
              <div><div class="settings-label">Full Name</div><div class="settings-desc" id="ep-name-val">—</div></div>
            </div>
            <div class="settings-row">
              <div><div class="settings-label">Email</div><div class="settings-desc" id="ep-email-val">—</div></div>
            </div>
            <div class="settings-row">
              <div><div class="settings-label">Department</div><div class="settings-desc" id="ep-dept-val">—</div></div>
            </div>
            <div class="settings-row">
              <div><div class="settings-label">Role</div><div class="settings-desc">Employee</div></div>
            </div>
          </div>
        </div>

        <!-- Employee Settings -->
        <div class="view" id="emp-settings">
          <div class="breadcrumb"><span>Dashboard</span><span class="sep">›</span><span class="current">Settings</span></div>
          <div class="section-title" style="margin-bottom:20px">Settings</div>
          <div id="shared-settings-emp"></div>
        </div>

        <!-- ===== ADMIN VIEWS ===== -->

        <!-- Admin Overview -->
        <div class="view" id="adm-overview">
          <div class="breadcrumb"><span>Admin</span><span class="sep">›</span><span class="current">Overview</span></div>
          <div class="stats-grid" id="adm-stats-grid"></div>
          <div class="section-header">
            <div class="section-title">Pending Requests</div>
            <button class="btn btn-ghost btn-sm" onclick="switchView('adm-requests','adm-nav')">View All →</button>
          </div>
          <div class="table-wrap" id="adm-recent-table"></div>
        </div>

        <!-- Admin All Requests -->
        <div class="view" id="adm-requests">
          <div class="breadcrumb"><span>Admin</span><span class="sep">›</span><span class="current">All Requests</span></div>
          <div class="section-header">
            <div class="section-title">All Requests</div>
            <div class="section-controls">
              <input class="search-input" placeholder="Search..." oninput="filterAdmRequests(this.value)" id="adm-search">
              <select class="select-input" onchange="filterAdmStatus(this.value)" id="adm-status-filter">
                <option value="">All Statuses</option>
                <option value="pending">Pending</option>
                <option value="approved">Approved</option>
                <option value="rejected">Rejected</option>
              </select>
              <select class="select-input" onchange="sortAdmRequests(this.value)">
                <option value="date-desc">Newest First</option>
                <option value="date-asc">Oldest First</option>
                <option value="urgency">By Urgency</option>
              </select>
            </div>
          </div>
          <div class="table-wrap" id="adm-requests-table"></div>
          <div class="pagination" id="adm-pagination"></div>
        </div>

        <!-- Admin Employees -->
        <div class="view" id="adm-employees">
          <div class="breadcrumb"><span>Admin</span><span class="sep">›</span><span class="current">Employees</span></div>
          <div class="section-title" style="margin-bottom:20px">Registered Employees</div>
          <div class="table-wrap" id="adm-emp-table"></div>
        </div>

        <!-- Admin Profile -->
        <div class="view" id="adm-profile">
          <div class="breadcrumb"><span>Admin</span><span class="sep">›</span><span class="current">Profile</span></div>
          <div class="profile-hero">
            <div class="profile-avatar-lg" id="adm-profile-avatar">A</div>
            <div>
              <div class="profile-name" id="adm-profile-name">Admin</div>
              <div class="profile-email" id="adm-profile-email">admin@selise.com</div>
              <div style="margin-top:8px"><span class="badge badge-high">Admin</span></div>
            </div>
          </div>
          <div class="settings-card">
            <div class="settings-row"><div><div class="settings-label">Full Name</div><div class="settings-desc" id="ap-name-val">—</div></div></div>
            <div class="settings-row"><div><div class="settings-label">Email</div><div class="settings-desc" id="ap-email-val">—</div></div></div>
            <div class="settings-row"><div><div class="settings-label">Role</div><div class="settings-desc">Portal Administrator</div></div></div>
          </div>
        </div>

        <!-- Admin Settings -->
        <div class="view" id="adm-settings">
          <div class="breadcrumb"><span>Admin</span><span class="sep">›</span><span class="current">Settings</span></div>
          <div class="section-title" style="margin-bottom:20px">Settings</div>
          <div id="shared-settings-adm"></div>
        </div>

      </div>
    </div>
  </div>
</div>

<!-- Notification Panel -->
<div class="notif-panel" id="notif-panel">
  <div class="notif-header">
    <div class="notif-title">Notifications</div>
    <button class="btn btn-ghost btn-sm" onclick="clearNotifPanel()">Clear all</button>
  </div>
  <div class="notif-list" id="notif-panel-list"></div>
</div>

<!-- Action Modal -->
<div class="modal-overlay" id="action-modal">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title" id="modal-title">Review Request</div>
      <button class="modal-close" onclick="closeModal()">✕</button>
    </div>
    <div id="modal-body"></div>
    <div class="flex-end" id="modal-footer"></div>
  </div>
</div>

<script src="script.js"></script>
</body>
</html>
