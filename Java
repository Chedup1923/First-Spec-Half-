function toggleEye(id, btn) {
  const inp = $(id);
  if(inp.type==='password') { inp.type='text'; btn.textContent='🙈'; }
  else { inp.type='password'; btn.textContent='👁'; }
}

function shakeEl(id) { const el=$(id); el.classList.add('shake'); setTimeout(()=>el.classList.remove('shake'),600); }

function checkStrength(val, prefix='') {
  const segs = ['s1','s2','s3','s4'].map(id=>$(prefix?prefix+id.slice(-1)===id?prefix+id:id:id));
  const colors = ['var(--danger)','var(--warning)','var(--accent)','var(--success)'];
  const labels = ['Too weak','Getting there','Good','Strong 💪'];
  let score=0;
  if(val.length>=10) score++;
  if(/[A-Z]/.test(val)) score++;
  if(/[a-z]/.test(val)) score++;
  if(/[^a-zA-Z]/.test(val)) score++;
  // find label
  const labelEl = $(prefix ? 'fp-strength-label' : 'strength-label');
  segs.forEach((s,i)=>{ if(s){ s.style.background = i<score ? colors[score-1] : 'var(--border)'; } });
  if(labelEl) labelEl.textContent = val ? labels[score-1]||labels[0] : 'Enter a password';
}

function checkMatch() {
  const p1=$('reg-password').value, p2=$('reg-confirm').value;
  const el=$('match-status');
  if(!p2) { el.textContent=''; return; }
  if(p1===p2) { el.style.color='var(--success)'; el.textContent='✓ Passwords match'; }
  else { el.style.color='var(--danger)'; el.textContent='✗ Passwords don\'t match'; }
}

function otpNext(el,gridId) {
  el.value = el.value.replace(/\D/,'');
  if(el.value && el.nextElementSibling && el.nextElementSibling.classList.contains('otp-input')) el.nextElementSibling.focus();
}
function otpBack(e,el,gridId) {
  if(e.key==='Backspace' && !el.value && el.previousElementSibling && el.previousElementSibling.classList.contains('otp-input')) el.previousElementSibling.focus();
}

