function reviewRequest(reqId, action) {
  const req = (ls.get('portal_requests')||[]).find(r=>r.id===reqId);
  if(!req) return;
  const title = action==='approve' ? 'Approve Request' : 'Reject Request';
  $('modal-title').textContent = title;
  $('modal-body').innerHTML = `
    <div style="margin-bottom:16px">
      <div style="font-size:0.85rem;color:var(--text-muted);margin-bottom:8px">Request by <strong>${esc(req.empName)}</strong></div>
      <div style="font-size:0.9rem"><strong>${esc(req.item)}</strong> × ${req.qty}</div>
      <div style="font-size:0.82rem;color:var(--text-muted);margin-top:4px">${esc(req.category)}</div>
    </div>
    <div class="form-group">
      <label class="form-label">Admin Note (optional)</label>
      <textarea class="form-input" id="admin-note" placeholder="Add a note for the employee..." style="min-height:80px"></textarea>
    </div>
  `;
  $('modal-footer').innerHTML = `
    <button class="btn btn-ghost" onclick="closeModal()">Cancel</button>
    <button class="btn ${action==='approve'?'btn-success-soft':'btn-danger'}" onclick="confirmReview('${reqId}','${action}')">${action==='approve'?'✓ Approve':'✗ Reject'}</button>
  `;
  openModal();
}

function confirmReview(reqId, action) {
  const note = $('admin-note').value.trim();
  const requests = ls.get('portal_requests')||[];
  const idx = requests.findIndex(r=>r.id===reqId);
  if(idx<0) return;
  requests[idx].status = action==='approve' ? 'approved' : 'rejected';
  requests[idx].adminNote = note;
  requests[idx].updatedAt = Date.now();
  ls.set('portal_requests',requests);

  // Push notification to employee
  const req = requests[idx];
  const notifs = ls.get('portal_notifs')||{};
  if(!notifs[req.empId]) notifs[req.empId]=[];
  notifs[req.empId].push({ id:uid(), key:'req_'+req.id, type:action==='approve'?'approved':'rejected', title:action==='approve'?'Request Approved 🎉':'Request Rejected', msg:`Your request for "${req.item}"${note?' — '+note:' has been '+requests[idx].status+'.'}`, ts:Date.now() });
  ls.set('portal_notifs',notifs);

  closeModal();
  toast(action==='approve'?'Request Approved':'Request Rejected', 'Employee notified.', action==='approve'?'success':'warning');
  renderAdminViews();
}

