    const users = ls.get('portal_users')||[];
    const user = users.find(u=>u.id===sessionId);
    if(user) { currentUser=user; currentRole=user.role; seedDemoData(user); setTimeout(()=>{ showPage('dashboard-page'); setupDashboard(); },600); }
  }

  // Hide loading
  setTimeout(()=>{
    const lo=$('loading-overlay');
    gsap.to(lo,{opacity:0,duration:0.5,onComplete:()=>lo.remove()});
  },800);
})();
