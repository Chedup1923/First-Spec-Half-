/* ========== REGISTER ========== */
function doRegister() {
  const fname = $('reg-fname').value.trim();
  const lname = $('reg-lname').value.trim();
  const email = $('reg-email').value.trim();
  const pass = $('reg-password').value;
  const confirm = $('reg-confirm').value;
  const dept = currentRole==='employee' ? $('reg-dept').value : 'Administration';

  if(!fname||!lname||!email||!pass||!confirm) { shakeEl('card-register'); toast('All fields required','Please fill in every field','error'); return; }
  if(!/\S+@\S+\.\S+/.test(email)) { shakeEl('card-register'); toast('Invalid email','','error'); return; }
  if(pass.length<10||pass.length>15) { shakeEl('card-register'); toast('Password length','Must be 10-15 characters','error'); return; }
  if(pass!==confirm) { shakeEl('card-register'); toast('Passwords don\'t match','','error'); return; }
  if(currentRole==='employee' && !dept) { toast('Select department','','error'); return; }

  const users = ls.get('portal_users')||[];
  if(users.find(u=>u.email===email)) { shakeEl('card-register'); toast('Email taken','This email is already registered','error'); return; }

  const user = { id:uid(), email, name:fname+' '+lname, role:currentRole, dept, password:pass, createdAt:Date.now() };
  users.push(user); ls.set('portal_users',users);
  $('card-register').classList.add('glow');
  setTimeout(()=>$('card-register').classList.remove('glow'),700);
  toast('Account created!','You can now sign in','success');
  switchAuthTab('login');
  $('login-email').value = email;
}

