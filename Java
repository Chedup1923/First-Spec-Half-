/* ========== PAGINATION ========== */
function renderPagination(containerId, currentPage, totalPages, onPage) {
  const el=$(containerId); if(!el) return;
  if(totalPages<=1) { el.innerHTML=''; return; }
  const start=(currentPage-1)*PAGE_SIZE+1;
  let html=`<div class="page-info">Page ${currentPage} of ${totalPages}</div>`;
  html+=`<button class="page-btn" onclick="(${onPage})(${currentPage-1})" ${currentPage<=1?'disabled':''}>‹</button>`;
  for(let p=1;p<=totalPages;p++){
    if(p===1||p===totalPages||Math.abs(p-currentPage)<=1) html+=`<button class="page-btn ${p===currentPage?'active':''}" onclick="(${onPage})(${p})">${p}</button>`;
    else if(Math.abs(p-currentPage)===2) html+=`<span style="color:var(--text-faint);padding:0 4px">…</span>`;
  }
  html+=`<button class="page-btn" onclick="(${onPage})(${currentPage+1})" ${currentPage>=totalPages?'disabled':''}>›</button>`;
  el.innerHTML=html;
}

/* ========== SORT ========== */
function sortRequests(arr, mode) {
  const u = { high:3, medium:2, low:1 };
  switch(mode) {
    case 'date-asc': return [...arr].sort((a,b)=>a.createdAt-b.createdAt);
    case 'date-desc': return [...arr].sort((a,b)=>b.createdAt-a.createdAt);
    case 'urgency': return [...arr].sort((a,b)=>u[b.urgency]-u[a.urgency]);
    case 'status': return [...arr].sort((a,b)=>a.status.localeCompare(b.status));
    default: return arr;
  }
}

/* ========== BADGES ========== */
function statusBadge(s) {
  const m = { pending:'badge-pending', approved:'badge-approved', rejected:'badge-rejected' };
  const icons = { pending:'⏳', approved:'✅', rejected:'❌' };
  return `<span class="badge ${m[s]||''}">${icons[s]||''}${s}</span>`;
}
function urgencyBadge(u) {
  const m = { low:'badge-low', medium:'badge-medium', high:'badge-high' };
  const icons = { low:'🟢', medium:'🟡', high:'🔴' };
  return `<span class="badge ${m[u]||''}">${icons[u]||''}${u}</span>`;
}
function emptyState(msg) {
  return `<div class="empty-state"><div class="empty-icon">📭</div><p>${esc(msg)}</p></div>`;
}

