function getEmpRequests() {
  const all = ls.get('portal_requests')||[];
  return all.filter(r=>r.empId===currentUser.id);
}

function renderEmployeeViews() {
  renderEmpStats();
  renderEmpRecentTable();
  renderEmpRequestsTable();
  renderEmpProfile();
  renderEmpNotifications();
  updateEmpBadge();
}

function renderEmpStats() {
  const reqs = getEmpRequests();
  const pending = reqs.filter(r=>r.status==='pending').length;
  const approved = reqs.filter(r=>r.status==='approved').length;
  const rejected = reqs.filter(r=>r.status==='rejected').length;
  $('emp-stats-grid').innerHTML = `
    <div class="stat-card indigo"><div class="stat-icon">📋</div><div class="stat-label">Total Requests</div><div class="stat-value">${reqs.length}</div><div class="stat-sub">All time submissions</div></div>
    <div class="stat-card indigo"><div class="stat-icon">⏳</div><div class="stat-label">Pending</div><div class="stat-value" style="color:var(--warning)">${pending}</div><div class="stat-sub">Awaiting review</div></div>
    <div class="stat-card indigo"><div class="stat-icon">✅</div><div class="stat-label">Approved</div><div class="stat-value" style="color:var(--success)">${approved}</div><div class="stat-sub">Ready for dispatch</div></div>
    <div class="stat-card indigo"><div class="stat-icon">❌</div><div class="stat-label">Rejected</div><div class="stat-value" style="color:var(--danger)">${rejected}</div><div class="stat-sub">See admin notes</div></div>
  `;
}

function renderEmpRecentTable() {
  const reqs = (ls.get('portal_requests')||[]).filter(r=>r.empId===currentUser.id).sort((a,b)=>b.createdAt-a.createdAt).slice(0,5);
  $('emp-recent-table').innerHTML = reqs.length ? `<table>${empTableHead()}${empTableBody(reqs)}</table>` : emptyState('No requests yet. Submit your first request!');
}

function renderEmpRequestsTable() {
  let reqs = (ls.get('portal_requests')||[]).filter(r=>r.empId===currentUser.id);
  if(empSearch) reqs = reqs.filter(r=>r.item.toLowerCase().includes(empSearch)||r.category.toLowerCase().includes(empSearch));
  reqs = sortRequests(reqs, empSort);
  const total = reqs.length;
  const pages = Math.ceil(total/PAGE_SIZE);
  empPage = Math.min(empPage, pages||1);
  const sliced = reqs.slice((empPage-1)*PAGE_SIZE, empPage*PAGE_SIZE);
  $('emp-requests-table').innerHTML = sliced.length ? `<table>${empTableHead()}${empTableBody(sliced)}</table>` : emptyState('No requests found.');
  renderPagination('emp-pagination', empPage, pages, p=>{ empPage=p; renderEmpRequestsTable(); });
  updateEmpBadge();
}

function empTableHead() {
  return `<thead><tr><th onclick="sortEmpRequests('item')">Item</th><th onclick="sortEmpRequests('category')">Category</th><th>Qty</th><th onclick="sortEmpRequests('urgency')">Urgency</th><th onclick="sortEmpRequests('status')">Status</th><th onclick="sortEmpRequests('date-desc')">Date</th></tr></thead>`;
}

function empTableBody(reqs) {
  return `<tbody>${reqs.map(r=>`
    <tr>
      <td><div class="request-detail-row"><span class="req-name">${esc(r.item)}</span></div></td>
      <td><span class="text-muted">${esc(r.category)}</span></td>
