/* ========== AUTH TABS ========== */
function switchAuthTab(tab) {
  qa('.auth-card').forEach(c=>c.classList.remove('active'));
  qa('.auth-tab').forEach(t=>t.classList.remove('active'));
  const tabMap = { login:0, register:1, forgot:2 };
  qa('.auth-tab')[tabMap[tab]].classList.add('active');
  const card = $('card-'+tab);
  card.classList.add('active');
  gsap.from(card, { scale:0.92, opacity:0, duration:0.45, ease:'back.out(1.5)' });

  // Reset steps
  if(tab==='login') { loginEmail=''; loginOtp=''; showLoginStep(1); }
  if(tab==='forgot') { fpOtp=''; showFpStep(1); }
}

/* ========== LOGIN FLOW ========== */
function showLoginStep(n) {
  ['login-step1','login-step2','login-step3'].forEach((id,i)=>{ $(id).style.display = (i===n-1)?'block':'none'; });
}

function loginStep1() {
  const email = $('login-email').value.trim();
  if(!email || !/\S+@\S+\.\S+/.test(email)) { shakeEl('card-login'); toast('Invalid email','Please enter a valid email address','error'); return; }
  loginEmail = email;
  loginOtp = otp6();
  $('login-demo-code').textContent = loginOtp;
  showLoginStep(2);
  gsap.from($('login-step2'),{opacity:0,y:10,duration:0.4,ease:'power2.out'});
}

function backToStep1() { showLoginStep(1); }

function loginStep2() {
  const inputs = qa('#login-otp-grid .otp-input');
  const entered = Array.from(inputs).map(i=>i.value).join('');
  if(entered.length<6) { shakeEl('card-login'); toast('Incomplete code','Enter all 6 digits','error'); return; }
  if(entered !== loginOtp) { shakeEl('card-login'); qa('#login-otp-grid .otp-input').forEach(i=>{i.value='';i.classList.add('error')}); setTimeout(()=>qa('#login-otp-grid .otp-input').forEach(i=>i.classList.remove('error')),1500); toast('Wrong code','Please try the demo code shown','error'); return; }
  showLoginStep(3);
  gsap.from($('login-step3'),{opacity:0,y:10,duration:0.4,ease:'power2.out'});
}

function loginStep3() {
  const pass = $('login-password').value;
  if(!pass) { shakeEl('card-login'); toast('Password required','Enter your password','error'); return; }
  // Check stored users
  const users = ls.get('portal_users') || [];
  const found = users.find(u => u.email===loginEmail && u.role===currentRole);
  if(!found) {
    // Allow demo login
    if(pass==='demo1234') {
      const demoUser = { id:uid(), email:loginEmail, name:loginEmail.split('@')[0], role:currentRole, dept:'General', createdAt:Date.now() };
      const arr = ls.get('portal_users')||[]; arr.push(demoUser); ls.set('portal_users',arr);
      finishLogin(demoUser);
    } else { shakeEl('card-login'); toast('Account not found','Register first or use password: demo1234','error'); }
    return;
  }
  if(found.password && found.password!==pass) { shakeEl('card-login'); toast('Wrong password','Try again','error'); return; }
  if($('remember-me').checked) ls.set('portal_session', found.id);
  finishLogin(found);
}

function finishLogin(user) {
  currentUser = user;
  ls.set('portal_session', user.id);
  seedDemoData(user);
  // Show dashboard immediately
  showPage('dashboard-page');
  setupDashboard();
  // Fade out auth page in background
  gsap.to($('auth-page'),{opacity:0,duration:0.4});
  toast('Welcome back!', user.name+' signed in successfully','success');
}

