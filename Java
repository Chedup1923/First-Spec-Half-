/* ========== SEED DEMO DATA ========== */
const DEMO_ITEMS = [
  {category:'Writing Instruments',item:'Blue Ballpoint Pens (Pack of 10)',qty:2,urgency:'medium',notes:'Prefer BIC brand'},
  {category:'Paper & Notebooks',item:'A4 Printing Paper (500 sheets)',qty:5,urgency:'high',notes:'For quarterly reports'},
  {category:'Desk Accessories',item:'Sticky Notes (Multi-colour)',qty:3,urgency:'low',notes:''},
  {category:'Folders & Binders',item:'Ring Binder A4 (Blue)',qty:4,urgency:'medium',notes:''},
  {category:'Printing Supplies',item:'Black Ink Cartridge HP 302',qty:1,urgency:'high',notes:'Printer is almost out of ink'},
];
const DEMO_EMPLOYEES = [
  {id:'demo-emp-1',email:'alice@selise.com',name:'Alice Chen',role:'employee',dept:'Engineering',createdAt:Date.now()-8.64e7*5},
  {id:'demo-emp-2',email:'bob@selise.com',name:'Bob Martinez',role:'employee',dept:'Marketing',createdAt:Date.now()-8.64e7*3},
  {id:'demo-emp-3',email:'carol@selise.com',name:'Carol Singh',role:'employee',dept:'HR',createdAt:Date.now()-8.64e7*1},
];

function seedDemoData(user) {
  const users = ls.get('portal_users')||[];
  DEMO_EMPLOYEES.forEach(e=>{ if(!users.find(u=>u.email===e.email)) users.push(e); });
  ls.set('portal_users',users);

  const requests = ls.get('portal_requests')||[];
  if(requests.length===0) {
    const empIds = ['demo-emp-1','demo-emp-2','demo-emp-3'];
    const statuses = ['pending','approved','rejected','pending','approved'];
    DEMO_ITEMS.forEach((item,i)=>{
      requests.push({
        id:uid(), empId:empIds[i%3], empName:DEMO_EMPLOYEES[i%3].name,
        empDept:DEMO_EMPLOYEES[i%3].dept,
        category:item.category, item:item.item, qty:item.qty,
        urgency:item.urgency, notes:item.notes,
        status:statuses[i], createdAt:Date.now()-8.64e7*(5-i),
        updatedAt:Date.now()-8.64e7*(4-i), adminNote:''
      });
    });
    ls.set('portal_requests',requests);
  }

  // Seed notifications for demo employees
  const notifs = ls.get('portal_notifs')||{};
  DEMO_EMPLOYEES.forEach(e=>{
    if(!notifs[e.id]) notifs[e.id]=[];
  });
  const empRequests = requests.filter(r=>r.status!=='pending');
  empRequests.forEach(r=>{
    const key = 'req_'+r.id;
    if(!notifs[r.empId]) notifs[r.empId]=[];
    if(!notifs[r.empId].find(n=>n.key===key)){
      notifs[r.empId].push({ id:uid(), key, type:r.status, title:r.status==='approved'?'Request Approved':'Request Rejected', msg:`Your request for "${r.item}" was ${r.status}.`, ts:r.updatedAt||Date.now() });
    }
  });
  ls.set('portal_notifs',notifs);
}

